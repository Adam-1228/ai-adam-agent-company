# Copy this file to .env on your local machine or EC2 server.
# Never commit the resulting .env. The repo root .gitignore already excludes it.

# LLM providers
# openai = OpenAI 키로 전체 client-ops 직원 실행.
# claude_only = Claude만 사용. mixed = Claude + Gemini Flash 혼합. mock = 호출 없음.
LLM_PROVIDER=mixed

# Anthropic (Claude) - 01, 03, 04, 05 사용
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini - 02 박실행 사용
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (Codex) - 04 최분석의 데이터 가공 스크립트 보조용
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# Messaging - 알림/에스컬레이션 전송용
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_ADAM=
TELEGRAM_CHAT_ID_OPS=

# Optional Slack (사용 시)
SLACK_WEBHOOK_OPS=
SLACK_WEBHOOK_ESCALATION=

# Runtime
CLIENT_OPS_ENV=local
CLIENT_OPS_TIMEZONE=Asia/Seoul

# Storage paths (모두 로컬 상대경로, 절대경로는 EC2 배포 시 덮어쓴다)
CLIENT_OPS_REPORTS_DIR=./reports
CLIENT_OPS_TASKS_DIR=./tasks

# Safety toggles
# true면 모든 외부 발송이 dry-run, 로그만 남기고 실제 전송하지 않는다.
DRY_RUN=true
# true면 환불/계약/가격/법적 키워드 감지 시 즉시 사람 에스컬레이션
HARD_ESCALATE_ON_LEGAL_KEYWORDS=true
