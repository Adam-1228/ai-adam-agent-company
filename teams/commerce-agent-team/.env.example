# Copy this file to .env on your local machine or EC2 server.

# mock = no external LLM calls. openai = use OpenAI Responses API.
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Runtime
COMMERCE_AGENT_ENV=local
COMMERCE_AGENT_TIMEZONE=Asia/Seoul

# Optional dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
