# Copy this file to .env on your local machine or EC2 server.
# On EC2 the canonical secret path is:
# /opt/ai-adam-agent-company/teams/commerce-agent-team/.env
# Never commit the resulting .env. Keep live publishing locked until Adam approves.

# mock = no external LLM calls. openai = use OpenAI Responses API.
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Channel API keys (Coupang / Amazon)
# The readiness checker only verifies whether these variables are present.
# It never prints API key values or account values.

# Coupang (WING Open API)
COUPANG_VENDOR_ID=
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# Amazon (SP-API + AWS IAM)
AMAZON_SP_CLIENT_ID=
AMAZON_SP_CLIENT_SECRET=
AMAZON_SP_REFRESH_TOKEN=
AMAZON_SP_AWS_ACCESS_KEY_ID=
AMAZON_SP_AWS_SECRET_ACCESS_KEY=
AMAZON_SP_ROLE_ARN=
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=

# Runtime
COMMERCE_AGENT_ENV=local
COMMERCE_AGENT_TIMEZONE=Asia/Seoul

# Optional dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
