[Unit]
Description=Commerce agent dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/ai-adam-agent-company/teams/commerce-agent-team
EnvironmentFile=/opt/ai-adam-agent-company/teams/commerce-agent-team/.env
ExecStart=/usr/bin/python3 dashboard/app.py --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
