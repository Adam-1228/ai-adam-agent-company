# Secrets and local environment
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa*
teams/*/config/*.local.json
teams/*/config/channel_accounts.json

# Python/runtime artifacts
__pycache__/
*.py[cod]
.venv/
venv/

# Local OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Runtime reports and agent execution logs
teams/*/runtime/
teams/*/reports/*
!teams/*/reports/.gitkeep
teams/*/logs/*
!teams/*/logs/.gitkeep
teams/*/workforce/runs/
teams/*/workforce/reports/*.md
teams/*/workforce/agents/*/outbox/
teams/*/agents/*/tone_cards/*
!teams/*/agents/*/tone_cards/.gitkeep

# Manual intake may contain real business data.
teams/*/data/manual_inbox/*
!teams/*/data/manual_inbox/.gitkeep
!teams/*/data/manual_inbox/example_candidates.csv
